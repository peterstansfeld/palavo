; Hunter Adams (vha3@cornell.edu)
; RGB generation for VGA driver
; mod by Bruce Land for 16 colors

; Program name
.program rgb5
;.side_set 1 ;opt
.origin 0                           ; we modify the PC, which needs absolute addresses


;#if SYS_CLOCK_FREQ_KHZ == 125000u

.define DELAY_LOOPS 6
.define SET_DELAY_LOOPS_DELAY 18
.define DELAY_LOOP_DELAY 24
.define GET_BIT_DELAY 0
.define BLANK_DELAY 2

;#elif SYS_CLOCK_FREQ_KHZ == 250000u

; .define DELAY_LOOPS 14
; .define SET_DELAY_LOOPS_DELAY 13
; .define DELAY_LOOP_DELAY 24

; ; #if COLOURS_PER_LINE == 2
; .define GET_BIT_DELAY 5
; ; #elif COLOURS_PER_LINE == 4
; .define GET_BIT_DELAY 2
; ; #endif
; .define BLANK_DELAY 7

;#endif

; ---- here's a 2-bit (2 colours per line) version ----

;#if COLOURS_PER_LINE == 2

jmp_table_0:
    jmp set_rgb_pins                ; can't use wrap

jmp_table_1:
    in null, 4                      ; shift the ISR 4 places to the right

;#elif COLOURS_PER_LINE == 4

; jmp_table_0:
;     jmp set_rgb_pins [2]            ; use wrap instead

; jmp_table_1:
;     in null, 4 [2]                     ; shift the ISR 4 places to the right
; .wrap

; jmp_table_2:
;     jmp jmp_table_2a

; jmp_table_3:
;     in null, 12 [2]                  ; shift the ISR 12 places to the right

; .wrap_target

;#endif

set_rgb_pins:
    mov pins, isr                   ; put the 4 colour bits on the colour pins

test_end_of_line:
    jmp x-- get_bit
; X is zero, which means we've out'ed all 640 1-bit values from the TX FIFO


public start:
    out x, 16 [BLANK_DELAY]         ; load x with 639 repeats (640 loops) and wait for the last pixel
    set pins, 0                     ; blank the colour pins

    wait 1 irq 5 [0]                ; wait for vsync active mode

    set y, DELAY_LOOPS [SET_DELAY_LOOPS_DELAY]    ; load a delay counter
delay_loop:
    jmp y-- delay_loop [DELAY_LOOP_DELAY]         ; delay, delay, delay

get_colours:
    out y, 16                       ; save the 2 or 4, 4-bit colours for this line

get_bit:
    mov isr, y                      ; put the 4-bit colours in the ISR
    out PC, 1 [GET_BIT_DELAY]       ; jump to the address stored in bit 0 of the OSR, ie jmp_table_0 or jmp_table_1

;#if COLOURS_PER_LINE == 4

; jmp_table_2a:
;     in null, 8                      ; shift the ISR 8 places to the right
;     jmp set_rgb_pins

;#endif


; Program name
.program rgb5_150_mhz
;.side_set 1 ;opt
.origin 0                           ; we modify the PC, which needs absolute addresses


